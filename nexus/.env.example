# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  NEXUS — Environment Variables
#  Copy to .env and fill in your values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Google Gemini API ─────────────────────────────────
# Required only for Gemini-powered OSINT classification.
# The system works fully in mock mode without this key.
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── API Server ────────────────────────────────────────
# Host and port for the FastAPI/Uvicorn server
API_HOST=0.0.0.0
API_PORT=8000

# ── Simulation Defaults ──────────────────────────────
# Random seed for reproducible simulations
SIM_SEED=42

# Episode length in simulated hours (168 = 1 week)
SIM_MAX_STEPS=168

# Per-step probability of random disruption (0.0 = deterministic demo)
SIM_DISRUPTION_PROBABILITY=0.02

# Auto-simulation speed (seconds per simulated hour)
SIM_SPEED=1.0

# ── Logging ───────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
